# Normalize line endings: treat as text and check out with LF.
* text=auto eol=lf

# Scripts
*.sh        text eol=lf
gradlew     text eol=lf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Source / config
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf
*.pro       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.properties text eol=lf

# Binary assets — never normalize, and mark for language stats.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.gif       binary
*.jar       binary
*.aar       binary
*.keystore  binary
*.gpg       binary

# Treat the gradle wrapper jar as binary.
gradle/wrapper/gradle-wrapper.jar binary

# Committed screenshot references are binary and shouldn't be diffed inline.
nativeplatformkit/src/test/screenshots/*.png binary

# Mark generated/vendored files for GitHub Linguist so language stats stay accurate.
gradlew            linguist-vendored
gradlew.bat        linguist-vendored
*.api              linguist-generated
