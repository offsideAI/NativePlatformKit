root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
# Jetpack Compose: @Composable functions are PascalCase by convention.
ktlint_function_naming_ignore_when_annotated_with = Composable
# Long lines are common in Compose/KDoc and not always auto-fixable; rely on review, not a hard gate.
ktlint_standard_max-line-length = disabled
# Files frequently hold a token class plus its CompositionLocal; don't force a 1:1 file/class match.
ktlint_standard_filename = disabled

[*.{yml,yaml,json}]
indent_size = 2

[*.toml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
