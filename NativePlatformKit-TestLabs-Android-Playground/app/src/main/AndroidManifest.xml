<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    >

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_testlabs"
        android:roundIcon="@mipmap/ic_launcher_testlabs_round"
        android:label="@string/testlabs_launcher_icon_label"
        android:supportsRtl="true"
        android:theme="@style/Offside.Helper.Testlabs.Splashscreen"
        >
        <activity
            android:name="ai.offside.mobile.android.helper.testlabs.nav.TestlabsMainActivity"
            android:theme="@style/Theme.Offside.Base.Retail"
            android:launchMode="singleInstance"
            android:exported="true"
            android:enabled="true"
            android:windowSoftInputMode="stateHidden|adjustResize"
            >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Boots the component-ui configuration (theme + activity lifecycle theming) at startup,
          mirroring the monorepo. UIComponentConfigInitializer depends on
          ApplicationComponentInitializer, so the (stubbed) ApplicationComponent is ready first.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge"
            >
            <meta-data
                android:name="ai.offside.mobile.android.component.ui.config.UIComponentConfigInitializer"
                android:value="androidx.startup"
                />
        </provider>
    </application>

</manifest>
