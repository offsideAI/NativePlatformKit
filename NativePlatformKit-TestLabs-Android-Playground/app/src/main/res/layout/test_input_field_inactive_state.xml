<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Offside.Redesign.InputField.LayoutContainerGrey"
    android:id="@+id/inputFieldLayoutThree_Container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/padding.xlarge"
    android:paddingEnd="@dimen/spacing.unset">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Offside.Redesign.InputField.TextLayoutBase"
        android:id="@+id/inputLayout_inactiveEmpty"
        android:layout_width="@dimen/spacing.match_constraint"
        android:layout_height="wrap_content"
        android:hint="@string/debug_ui_redesign_input_field_inactive_unfilled_hint"
        android:labelFor="@+id/inputEditText_inactiveEmpty"
        app:layout_constraintBottom_toTopOf="@+id/inputLayout_inactiveFilled"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            style="@style/Offside.Redesign.InputField.EditTextBase.Inactive"
            android:id="@+id/inputEditText_inactiveEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Offside.Redesign.InputField.TextLayoutBase"
        android:id="@+id/inputLayout_inactiveFilled"
        android:layout_width="@dimen/spacing.match_constraint"
        android:layout_height="wrap_content"
        android:hint="@string/debug_ui_redesign_input_field_inactive_hint"
        android:labelFor="@+id/inputEditText_inactiveFilled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inputLayout_inactiveEmpty">

        <com.google.android.material.textfield.TextInputEditText
            style="@style/Offside.Redesign.InputField.EditTextBase.Inactive"
            android:id="@+id/inputEditText_inactiveFilled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/debug_ui_redesign_input_field_filled_text" />

    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
