        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_title"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.TitleMediumTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_title"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.TitleSmallTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
