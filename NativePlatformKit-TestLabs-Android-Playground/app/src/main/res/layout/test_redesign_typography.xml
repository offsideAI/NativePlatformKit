            android:text="@string/debug_ui_redesign_type_display"
            android:textAppearance="@style/Offside.Redesign.DisplayLargeTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_display"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.DisplayMediumTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_display"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.DisplaySmallTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="@string/debug_ui_redesign_type_headline"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.HeadlineLargeTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_headline"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.HeadlineMediumTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_headline"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.HeadlineSmallTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
