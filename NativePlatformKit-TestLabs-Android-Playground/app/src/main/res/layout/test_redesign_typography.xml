            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_label"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.LabelMediumTextStyle" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_ui_redesign_type_label"
            android:textColor="?attr/offside_onSurface"
            android:textAppearance="@style/Offside.Redesign.LabelSmallTextStyle" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

