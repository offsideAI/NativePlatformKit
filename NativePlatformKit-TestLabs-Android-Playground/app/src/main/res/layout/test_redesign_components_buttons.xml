<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/gutter.xsmall"
        android:layout_marginRight="@dimen/gutter.xsmall"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/button_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin.small"
            android:orientation="vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                style="@style/Offside.Redesign.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/debug_ui_redesign_primary_button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_disabled"
                style="@style/Offside.Redesign.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="@string/debug_ui_redesign_primary_disabled_btn" />

           <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    style="@style/Offside.Redesign.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/debug_ui_redesign_primary_half_btn" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Offside.Redesign.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:layout_weight="1"
                    android:text="@string/debug_ui_redesign_primary_half_btn" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/margin.small"
                android:layout_marginBottom="@dimen/margin.small"
                android:background="?attr/offside_inverseSurface">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_white_overlay"
                    style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="true"
                    android:text="@string/debug_ui_redesign_primary_overlay_btn" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_white_overlay_disabled"
                    style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:text="@string/debug_ui_redesign_primary_overlay_disabled_btn" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_white_overlay_half"
                    style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/debug_ui_redesign_primary_overlay_half_btn" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_submit_white_overlay_disabled_half"
                        style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:layout_weight="1"
                        android:text="@string/debug_ui_redesign_primary_overlay_half_btn" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                style="@style/Offside.Redesign.Button.Secondary"
                android:id="@+id/btn_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="@string/debug_ui_redesign_secondary_btn" />

            <com.google.android.material.button.MaterialButton
                style="@style/Offside.Redesign.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/debug_ui_redesign_secondary_enabled_btn" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    style="@style/Offside.Redesign.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/debug_ui_redesign_secondary_half_btn" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Offside.Redesign.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:layout_weight="1"
                    android:text="@string/debug_ui_redesign_secondary_half_btn" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tertiary"
                style="@style/Offside.Redesign.Button.Tertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin.medium"
                android:layout_marginLeft="@dimen/margin.medium"
                android:layout_marginTop="@dimen/margin.medium"
                android:layout_marginEnd="@dimen/margin.medium"
                android:layout_marginRight="@dimen/margin.medium"
                android:text="@string/debug_ui_redesign_tertiary_btn" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin.small"
                android:background="@drawable/layout_border"
                android:orientation="vertical">
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding.xsmall"
                    android:textColor="?attr/offside_primary"
                    android:textAppearance="@style/Offside.Redesign.HeadlineLargeTextStyle"
                    android:text="@string/debug_ui_redesign_micro_buttons_label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/margin.xxsmall"
                    android:layout_marginStart="@dimen/sys.spacing.04"
                    android:layout_marginEnd="@dimen/margin.xxsmall"
                    android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_micro"
                    style="@style/Offside.Redesign.Button.Micro.Alternate"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/sys.spacing.28"
                    android:text="@string/debug_ui_redesign_micro_buttons_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_disabled"
                        style="@style/Offside.Redesign.Button.Micro.Alternate"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/debug_ui_redesign_micro_buttons_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/padding.xsmall"
                    android:layout_marginStart="@dimen/sys.spacing.04"
                    android:orientation="vertical">

                   <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_blue"
                        style="@style/Offside.Redesign.Button.Micro.Blue"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:text="@string/debug_ui_redesign_micro_buttons_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_blue_disabled"
                        style="@style/Offside.Redesign.Button.Micro.Blue"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:enabled="false"
                        android:layout_weight="1"
                        android:text="@string/debug_ui_redesign_micro_buttons_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/margin.xxsmall"
                    android:layout_marginStart="@dimen/sys.spacing.04"
                    android:layout_marginEnd="@dimen/margin.xxsmall"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_icon"
                        style="@style/Offside.Redesign.Button.Micro.Alternate.Icon"
                        app:icon="@drawable/ic_decorative_placeholder_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:text="@string/debug_ui_redesign_micro_buttons_payment_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_icon2"
                        style="@style/Offside.Redesign.Button.Micro.Alternate.Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:enabled="false"
                        android:text="@string/debug_ui_redesign_micro_buttons_payment_text"
                        app:icon="@drawable/ic_decorative_placeholder_regular" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/margin.xxsmall"
                    android:layout_marginStart="@dimen/sys.spacing.04"
                    android:layout_marginEnd="@dimen/margin.xxsmall"
                    android:orientation="vertical">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_blue_icon"
                        style="@style/Offside.Redesign.Button.Micro.Blue.Icon"
                        app:icon="@drawable/ic_decorative_placeholder_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.32"
                        android:text="@string/debug_ui_redesign_micro_buttons_payment_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_blue_icon_disabled"
                        style="@style/Offside.Redesign.Button.Micro.Blue.Icon"
                        app:icon="@drawable/ic_decorative_placeholder_regular"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.32"
                        android:enabled="false"
                        android:text="@string/debug_ui_redesign_micro_buttons_payment_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/offside_primary"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_sop_icon"
                        style="@style/Offside.Redesign.Button.Micro.Blue.SopIcon"
                        app:icon="@drawable/ic_decorative_reminders"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:text="@string/debug_ui_redesign_micro_buttons_sop_label"
                        />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_micro_sop_icon_disabled"
                        style="@style/Offside.Redesign.Button.Micro.Blue.SopIcon"
                        app:icon="@drawable/ic_decorative_reminders"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sys.spacing.28"
                        android:enabled="false"
                        android:text="@string/debug_ui_redesign_micro_buttons_sop_label" />
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin.small"
                android:background="@drawable/layout_border"
                android:orientation="vertical">
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding.xsmall"
                    android:textColor="?attr/offside_primary"
                    android:textAppearance="@style/Offside.Redesign.HeadlineLargeTextStyle"
                    android:text="@string/debug_ui_redesign_jumbo_buttons_label" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_jumbo_half"
                        style="@style/Offside.Redesign.Button.Primary.Jumbo.Icon"
                        app:icon="@drawable/ic_decorative_placeholder_regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin.medium"
                        android:layout_weight="1"
                        android:text="@string/debug_ui_redesign_jumbo_buttons_label_pay" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_jumbo_half_disabled"
                        style="@style/Offside.Redesign.Button.Primary.Jumbo.Icon"
                        app:icon="@drawable/ic_decorative_placeholder_regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin.medium"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/debug_ui_redesign_jumbo_buttons_label_pay" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_jumbo_full"
                        style="@style/Offside.Redesign.Button.Primary.Jumbo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debug_ui_redesign_jumbo_buttons_label_send" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_jumbo_full_icon"
                        style="@style/Offside.Redesign.Button.Primary.Jumbo.Icon"
                        app:icon="@drawable/ic_feature_ecommerce_payment_send_blue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debug_ui_redesign_jumbo_buttons_label_pay" />
                </LinearLayout>
            </LinearLayout>

            <!--<com.google.android.material.bottomnavigation.BottomNavigationView
                style="@style/Offside.Redesign.BottomNavigationView"
                android:id="@+id/bottomNavigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="@dimen/margin.medium"
                android:layout_marginStart="@dimen/margin.medium"
                android:layout_marginEnd="@dimen/margin.medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />-->

            <com.google.android.material.materialswitch.MaterialSwitch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin.medium"
                android:checked="true"
                android:visibility="gone"
                android:text="@string/debug_ui_redesign_enabled"
                 />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/checkbox_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin.medium"
            android:layout_marginStart="@dimen/margin.medium"
            android:layout_marginEnd="@dimen/margin.medium"
            app:layout_constraintTop_toBottomOf="@+id/button_layout"
            app:layout_constraintStart_toStartOf="parent"
            android:orientation="vertical">

            <ai.offside.mobile.android.component.ui.a11y.CheckBoxA11y
                style="@style/Offside.Redesign.CheckboxStyle.Left"
                android:id="@+id/checkbox1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:text="@string/debug_ui_redesign_enabled" />

            <ai.offside.mobile.android.component.ui.a11y.CheckBoxA11y
                android:id="@+id/checkbox2"
                android:enabled="false"
                style="@style/Offside.Redesign.CheckboxStyle.Left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin.xxsmall"
                android:text="@string/debug_ui_redesign_disabled" />

            <ai.offside.mobile.android.component.ui.a11y.CheckBoxA11y
                android:id="@+id/checkbox3"
                android:checked="true"
                android:enabled="false"
                style="@style/Offside.Redesign.CheckboxStyle.Left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:text="@string/debug_ui_redesign_disabled_selected" />
            </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin.medium"
            android:layout_marginStart="@dimen/margin.medium"
            android:layout_marginEnd="@dimen/margin.medium"
            app:layout_constraintTop_toBottomOf="@id/checkbox_layout"
            app:layout_constraintStart_toStartOf="@id/checkbox_layout"
            android:orientation="vertical">

            <RadioGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:checkedButton="@+id/one"
                android:layoutDirection="ltr"
                android:id="@+id/radio_grp1"
                android:orientation="horizontal">

                    <ai.offside.mobile.android.component.ui.a11y.RadioButtonA11y
                        style ="@style/Offside.Redesign.RadioButtonStyle.Left"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/one"
                        android:checked="true"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginEnd="@dimen/margin.xxsmall"
                        android:text = "@string/debug_ui_redesign_radiob1"/>

                    <ai.offside.mobile.android.component.ui.a11y.RadioButtonA11y
                        style="@style/Offside.Redesign.RadioButtonStyle.Left"
                        android:id="@+id/two"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginStart="@dimen/margin.xxlarge"
                        android:text="@string/debug_ui_redesign_radiob2"/>
            </RadioGroup>

            <RadioGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkedButton="@+id/three"
                android:layout_gravity="left"
                android:layoutDirection="ltr"
                android:orientation="horizontal">

                    <ai.offside.mobile.android.component.ui.a11y.RadioButtonA11y
                        style="@style/Offside.Redesign.RadioButtonStyle.Left"
                        android:id="@+id/three"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:checked="false"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:text="@string/debug_ui_redesign_radiob3"/>

                    <ai.offside.mobile.android.component.ui.a11y.RadioButtonA11y
                        style="@style/Offside.Redesign.RadioButtonStyle.Left"
                        android:id="@+id/four"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:checked="true"
                        android:layout_marginStart="@dimen/margin.xxlarge"
                        android:text="@string/debug_ui_redesign_radiob4"/>

            </RadioGroup>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>