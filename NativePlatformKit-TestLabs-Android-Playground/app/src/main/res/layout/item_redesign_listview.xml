<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_marginHorizontal="@dimen/margin.small"
    android:layout_height="wrap_content">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/header_label"
        android:layout_width="@dimen/spacing.unset"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin.xsmall"
        app:layout_constraintHorizontal_bias="0.0"
        android:text="@string/debug_ui_redesign_type_display"
        android:textColor="?attr/offside_onSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/right_arrow"
        android:textAppearance="@style/Offside.Redesign.DisplaySmallTextStyle" />

    <ImageView android:id="@+id/right_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_actionable_header_back_arrow"
        android:rotation="180"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="@+id/header_label"
        app:layout_constraintBottom_toBottomOf="@+id/header_label"
        app:layout_constraintEnd_toEndOf="parent" />

    <View app:layout_constraintTop_toBottomOf="@+id/header_label"
        android:layout_marginTop="@dimen/margin.xsmall"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/offside_surface"/>

</androidx.constraintlayout.widget.ConstraintLayout>