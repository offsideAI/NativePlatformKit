<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/offside_primaryVariant"
    tools:context=".nav.controls.TestUIRedesignProfileAndSettingsBarFragment">

    <ai.offside.mobile.android.component.ui.segment.TabBarLayout
        android:id="@+id/materialButtonToggleGroup"
        style="@style/Offside.Redesign.SegmentedBar.Custom"
        android:layout_width="@dimen/spacing.match_constraint"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/gutter.xsmall"
        android:layout_marginTop="@dimen/margin.medium"
        android:layout_marginEnd="@dimen/gutter.xsmall"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.tabs.TabItem
            style="@style/Offside.Redesign.SegmentedBar.Custom.TabItem"
            android:icon="@drawable/ic_profile_with_bg_circle"
            android:text="@string/debug_ui_redesign_profile_tab_label" />

        <com.google.android.material.tabs.TabItem
            style="@style/Offside.Redesign.SegmentedBar.Custom.TabItem.Divider"
            android:icon="@drawable/ic_security_bg_circle"
            android:text="@string/debug_ui_redesign_security_tab_label" />

        <com.google.android.material.tabs.TabItem
            style="@style/Offside.Redesign.SegmentedBar.Custom.TabItem.Divider"
            android:icon="@drawable/ic_decorative_alerts_bg_circle"
            android:text="@string/debug_ui_redesign_alerts_tab_label" />
    </ai.offside.mobile.android.component.ui.segment.TabBarLayout>

    <View
        android:id="@+id/ll_background"
        android:layout_width="match_parent"
        android:layout_height="@dimen/spacing.match_constraint"
        android:background="@drawable/segment_bar_custom_background_image"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/materialButtonToggleGroup"
        />
</androidx.constraintlayout.widget.ConstraintLayout>
