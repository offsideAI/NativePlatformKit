<?xml version="1.0" encoding="utf-8"?>

        <androidx.constraintlayout.widget.ConstraintLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@+id/btn_micro"
            app:layout_constraintStart_toEndOf="@+id/btn_micro">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_icon_link_01"
            style="@style/Offside.Redesign.Button.Icon.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin.xxsmall"
            android:enabled="false"
            android:text="@string/debug_ui_redesign_micro_buttons_payment_text"
            app:icon="@drawable/ic_actionable_edit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_icon_link_02"
            style="@style/Offside.Redesign.Button.Icon.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin.xxsmall"
            android:enabled="false"
            android:text="@string/debug_ui_redesign_button_icon_with_link_label"
            app:icon="@drawable/ic_actionable_edit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_icon_link_01" />
        </androidx.constraintlayout.widget.ConstraintLayout>
