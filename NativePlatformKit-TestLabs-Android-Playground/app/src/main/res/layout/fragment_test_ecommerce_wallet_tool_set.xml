<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="featureDataWithTwo"
            type="ai.offside.mobile.android.component.ui.tile.ecommercewallettoolset.data.EcommerceWalletToolSetData" />

        <variable
            name="featureDataWithThree"
            type="ai.offside.mobile.android.component.ui.tile.ecommercewallettoolset.data.EcommerceWalletToolSetData" />

        <variable
            name="featureDataWithMax"
            type="ai.offside.mobile.android.component.ui.tile.ecommercewallettoolset.data.EcommerceWalletToolSetData" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/offside_surfaceContainerLow">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin.small">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

                <ai.offside.mobile.android.component.ui.tile.ecommercewallettoolset.EcommerceWalletToolSet
                    android:id="@+id/ecommerce_wallet_tool_set_one"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    />

                <com.google.android.material.divider.MaterialDivider
                    style="@style/Offside.Redesign.Divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin.small"
                    />

                <ai.offside.mobile.android.component.ui.tile.ecommercewallettoolset.EcommerceWalletToolSet
                    android:id="@+id/ecommerce_wallet_tool_set_two"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    />

                <com.google.android.material.divider.MaterialDivider
                    style="@style/Offside.Redesign.Divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin.small"
                    />

                <ai.offside.mobile.android.component.ui.tile.ecommercewallettoolset.EcommerceWalletToolSet
                    android:id="@+id/ecommerce_wallet_tool_set_three"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</layout>