<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:bind="http://schemas.android.com/apk/res-auto"
    >
    <data>
        <variable
            name="viewModel"
            type="ai.offside.mobile.android.helper.testlabs.color.generator.ColorGeneratorViewModel"
            />
    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <com.google.android.material.materialswitch.MaterialSwitch
            style="@style/Offside.Redesign.SwitchToggleStyle"
            android:id="@+id/color_generator_input_brighter_darker_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/color_generator_dark_colors_switch"
            android:checked="@={viewModel.generateDarkColors}"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>