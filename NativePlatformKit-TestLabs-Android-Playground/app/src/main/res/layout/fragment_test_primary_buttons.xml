<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginLeft="@dimen/gutter.xsmall"
    android:layout_marginRight="@dimen/gutter.xsmall"
    android:orientation="vertical"
    tools:context="ai.offside.mobile.android.helper.testlabs.nav.TestPrimaryButtonsFragment">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            style="@style/Offside.Redesign.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/debug_ui_redesign_primary_button"
            android:layout_marginTop="@dimen/margin.small"
            app:layout_constraintBottom_toTopOf="@+id/btn_submit_disabled"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_disabled"
            style="@style/Offside.Redesign.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="@string/debug_ui_redesign_primary_disabled_btn"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout2"
            app:layout_constraintTop_toBottomOf="@id/btn_submit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            />

        <LinearLayout
            android:id="@+id/linearLayout2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin.small"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_submit_disabled">

            <com.google.android.material.button.MaterialButton
                style="@style/Offside.Redesign.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/debug_ui_redesign_primary_half_btn" />

            <com.google.android.material.button.MaterialButton
                style="@style/Offside.Redesign.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/debug_ui_redesign_primary_half_btn" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin.xxlarge"
            android:background="?attr/offside_secondaryVariant"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/linearLayout2"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_white_overlay"
                style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="true"
                android:text="@string/debug_ui_redesign_primary_overlay_btn" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_white_overlay_disabled"
                style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="@string/debug_ui_redesign_primary_overlay_disabled_btn" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_white_overlay_half"
                    style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/debug_ui_redesign_primary_overlay_half_btn" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_white_overlay_disabled_half"
                    style="@style/Offside.Redesign.Button.Primary.WhiteOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="@string/debug_ui_redesign_primary_overlay_half_btn" />
            </LinearLayout>
        </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>