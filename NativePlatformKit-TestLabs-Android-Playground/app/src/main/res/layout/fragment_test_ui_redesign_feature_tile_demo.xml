<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/offside_surfaceContainerLowest"
    tools:context=".nav.tile.TestUIRedesignImageTileDemoFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin.small"
        android:importantForAccessibility="no"
        android:orientation="vertical">

        <ai.offside.mobile.android.component.ui.tile.feature.FeatureTile
            android:id="@+id/simple_feature_tile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryIcon="@drawable/ic_general_badge_custom"
            app:tileTitle="@string/feature_tile_title"
            />

        <ai.offside.mobile.android.component.ui.tile.feature.FeatureTile
            android:id="@+id/notification_feature_tile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryIcon="@drawable/ic_general_badge_custom"
            app:tileBadgeCount="@integer/feature_tile_badge_count"
            app:tileSupplementary="@string/feature_tile_supplementary_one_line"
            app:tileTitle="@string/feature_tile_title"
            />

        <ai.offside.mobile.android.component.ui.tile.feature.FeatureTile
            android:id="@+id/notification_large_feature_tile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryIcon="@drawable/ic_general_badge_custom"
            app:tileBadgeCount="@integer/feature_tile_badge_count"
            app:tileSupplementary="@string/feature_tile_supplementary"
            app:tileTitle="@string/feature_tile_title"
            />

        <ai.offside.mobile.android.component.ui.tile.feature.FeatureTile
            android:id="@+id/notification_feature_tile_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryIcon="@drawable/ic_general_badge_custom"
            app:secondaryIcon="@drawable/ic_actionable_caret"
            app:tileBadgeCount="@integer/feature_tile_badge_count"
            app:tileSupplementary="@string/feature_tile_supplementary"
            app:tileTitle="@string/feature_tile_title" />
    </LinearLayout>
</ScrollView>