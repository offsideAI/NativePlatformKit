<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/date_selection"
        style="@style/Offside.Redesign.TitleLargeTextStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin.small"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/date_picker_actions"
        style="@style/Offside.Redesign.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin.small"
        android:text="Date Picker"
        app:layout_constraintTop_toBottomOf="@+id/date_selection" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/calendar_forward_actions"
        style="@style/Offside.Redesign.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin.small"
        android:text="Date-Forward"
        app:layout_constraintTop_toBottomOf="@+id/date_picker_actions" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/calendar_backward_actions"
        style="@style/Offside.Redesign.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin.small"
        android:text="Date-Backward"
        app:layout_constraintTop_toBottomOf="@+id/calendar_forward_actions" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/calendar_range_actions"
        style="@style/Offside.Redesign.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin.small"
        android:text="Date-Range"
        app:layout_constraintTop_toBottomOf="@+id/calendar_backward_actions" />

</androidx.constraintlayout.widget.ConstraintLayout>