<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/amountInputFieldDisabledContainerLayout">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Offside.Redesign.InputField.TextLayoutBase.Amount.CustomDividerBox"
        android:id="@+id/amountInputFieldDisabledLayout"
        android:layout_width="@dimen/spacing.match_constraint"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/margin.xsmall"
        android:hint="@string/debug_ui_redesign_amount_input_hint"
        android:labelFor="@+id/amountInputFieldDisabledText"
        android:orientation="vertical"
        app:errorTextAppearance="@style/Offside.Redesign.InputField.ErrorTextAppearance.Amount"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            style="@style/Offside.Redesign.InputField.EditTextBase.Amount"
            android:id="@+id/amountInputFieldDisabledText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/debug_ui_redesign_amount_input_default_text" />

        <com.google.android.material.divider.MaterialDivider
            style="@style/Offside.Redesign.InputField.DividerStyle.Amount"
            android:id="@+id/amountInputFieldDisabled_divider" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Offside.Redesign.InputField.TextLayoutBase.Amount.DropDownBox"
        android:id="@+id/amountInputFieldDisabledDropdownLayout"
        android:layout_width="@dimen/spacing.match_constraint"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/margin.xsmall"
        android:hint="@string/debug_ui_redesign_amount_input_hint"
        android:labelFor="@+id/amountInputFieldDisabledDropdownText"
        android:orientation="vertical"
        app:endIconContentDescription="@string/debug_ui_redesign_dropdown_end_icon_content_description"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/amountInputFieldDisabledLayout">

        <com.google.android.material.textfield.TextInputEditText
            style="@style/Offside.Redesign.InputField.EditTextBase.Amount"
            android:id="@+id/amountInputFieldDisabledDropdownText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/debug_ui_redesign_amount_input_default_text" />

        <com.google.android.material.textview.MaterialTextView
            style="@style/Offside.Redesign.InputField.SubInfoTextStyle.Amount"
            android:id="@+id/amountInputFieldDisabledDropdownSecondaryInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/debug_ui_redesign_amount_input_helper_text" />

        <com.google.android.material.divider.MaterialDivider
            style="@style/Offside.Redesign.InputField.DividerStyle.Amount"
            android:id="@+id/amountInputFieldDisabledDropdown_divider" />
    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>