<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="?offside_onPrimary"
    android:orientation="horizontal">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button"
        style="@style/Offside.Redesign.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/gutter.xsmall"
        android:layout_marginBottom="@dimen/margin.xxlarge"
        android:layout_marginTop="@dimen/margin.medium"
        android:text="@string/primary_action_label"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/button2"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button2"
        style="@style/Offside.Redesign.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/gutter.xsmall"
        android:layout_marginBottom="@dimen/margin.xxlarge"
        android:layout_marginTop="@dimen/margin.medium"
        android:layout_marginEnd="@dimen/margin.xxsmall"
        android:text="@string/secondary_action_label"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>