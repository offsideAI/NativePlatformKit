<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/actionable_icons_decorative_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:descendantFocusability="blocksDescendants"
    android:paddingHorizontal="@dimen/padding.xxlarge">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/actionable_icons_decorative_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/padding.xxlarge"
        android:text="@string/debug_ui_redesign_bottom_sheet_icon_label"
        android:textAppearance="@style/Offside.Redesign.BodyLargeTextStyle"
        android:textColor="?attr/offside_onSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        style="@style/Offside.Redesign.Icons.Actionable"
        android:id="@+id/actionable_icons_decorative_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_actionable_bottom_sheet_arrow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.divider.MaterialDivider
        style="@style/Offside.Redesign.Divider"
        android:id="@+id/actionable_icons_decorative_divider"
        android:layout_width="@dimen/spacing.match_constraint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>