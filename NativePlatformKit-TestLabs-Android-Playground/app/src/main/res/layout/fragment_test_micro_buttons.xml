<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/checkbox_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin.medium"
        android:layout_marginStart="@dimen/gutter.xsmall"
        android:layout_marginEnd="@dimen/gutter.xsmall"
        android:orientation="vertical"
        android:background="@drawable/layout_border"
        tools:context="ai.offside.mobile.android.helper.testlabs.nav.TestMicroButtonsFragment">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/title_textview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding.xsmall"
            android:textColor="?attr/offside_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:textAppearance="@style/Offside.Redesign.HeadlineLargeTextStyle"
            android:text="@string/debug_ui_redesign_micro_buttons_label" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/enabled_switch"
            android:text="@string/debug_ui_redesign_enabled_switch_label"
            app:layout_constraintBottom_toTopOf="@id/linearLayout4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_textview"
            android:layout_gravity="end"/>

        <LinearLayout
            android:id="@+id/linearLayout4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin.xxsmall"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/enabled_switch">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/sys.spacing.96"
                android:backgroundTint="?attr/offside_onPrimary"
                >

                <include layout="@layout/test_micro_button_card_layout"
                    android:id="@+id/micro_buttons_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin.small"
                    android:layout_marginBottom="@dimen/margin.xxsmall"
                    android:layout_gravity="end|bottom"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/sys.spacing.96"
                android:backgroundTint="?attr/offside_onPrimary"
                >
                <include layout="@layout/test_micro_button_with_icon_card_layout"
                    android:id="@+id/button_icon_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin.large"
                    android:layout_marginStart="@dimen/margin.large"
                    android:layout_marginBottom="@dimen/margin.xxsmall"
                    android:layout_gravity="end|bottom"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/sys.spacing.96"
                android:backgroundTint="?attr/offside_secondaryVariant"
                >

                <include layout="@layout/test_sop_button_card_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin.xxsmall"
                    android:layout_marginBottom="@dimen/margin.xxsmall"
                    android:layout_gravity="end|bottom"/>
            </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>