<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Offside.Redesign.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">?attr/offside_inverseSurface</item>
        <item name="animationMode">slide</item>
        <item name="android:layout_margin">@dimen/margin.small</item>
        <item name="android:padding">@dimen/spacing.unset</item>
        <item name="shapeAppearance">@style/ShapeAppearance.M3.Sys.Shape.Corner.Medium</item>
    </style>

    <style name="Offside.Redesign.Snackbar.TextView" parent="Widget.Material3.Snackbar.TextView">
        <item name="android:textAppearance">@style/Offside.Redesign.TitleSmallTextStyle</item>
        <item name="android:textColor">?attr/offside_inverseOnSurface</item>
        <item name="android:paddingTop">@dimen/padding.xxlarge</item>
        <item name="android:paddingBottom">@dimen/padding.xxlarge</item>
        <item name="android:paddingLeft">@dimen/spacing.unset</item>
        <item name="android:paddingRight">@dimen/spacing.unset</item>
        <item name="android:layout_marginLeft">@dimen/margin.small</item>
        <item name="android:layout_marginRight">@dimen/margin.small</item>
    </style>

    <style name="Offside.Redesign.Button.TextButton.Snackbar" parent="Widget.Material3.Button.TextButton.Snackbar">
        <item name="android:textColor">?attr/offside_inversePrimary</item>
        <item name="android:textAppearance">@style/Offside.Redesign.TitleSmallTextStyle</item>
        <item name="android:paddingTop">@dimen/padding.large</item>
        <item name="android:paddingBottom">@dimen/padding.large</item>
        <item name="android:paddingLeft">@dimen/spacing.unset</item>
        <item name="android:paddingRight">@dimen/padding.xxlarge</item>
    </style>
</resources>