<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Offside.Redesign.InputField" />

    <style name="Offside.Redesign.InputField.LayoutContainerPrimary">
        <item name="android:background">?attr/offside_primary</item>
    </style>

    <style name="Offside.Redesign.InputField.LayoutContainerWhite">
        <item name="android:background">?attr/offside_surfaceContainer</item>
    </style>

    <style name="Offside.Redesign.InputField.LayoutContainerGrey">
        <item name="android:background">?attr/offside_surfaceContainerLowest</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="hintTextColor">?attr/offside_onSurfaceVariantLow</item>
        <item name="android:textColorHint">?attr/offside_onSurfaceVariantLow</item>
        <item name="android:paddingStart">@dimen/spacing.unset</item>
        <item name="android:paddingEnd">@dimen/spacing.unset</item>
        <item name="boxStrokeColor">@color/selector_input_layout_box_stroke_default_color</item>
        <item name="cursorColor">?attr/offside_accent</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase.Active">
        <item name="endIconDrawable">@drawable/ic_actionable_clear</item>
        <item name="endIconCheckable">false</item>
        <item name="endIconMode">clear_text</item>
        <item name="endIconTint">@null</item>
        <item name="endIconTintMode">multiply</item>
        <item name="errorIconDrawable">@null</item>
        <item name="boxStrokeErrorColor">?attr/offside_error</item>
        <item name="cursorErrorColor">?attr/offside_accent</item>
        <item name="errorTextAppearance">@style/Offside.Redesign.InputField.ErrorTextAppearance</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase.Active.EmptyWhite">
        <item name="boxStrokeColor">@color/selector_input_layout_box_stroke_empty_white_color</item>
        <item name="hintTextColor">?attr/offside_onSecondaryVariant</item>
        <item name="android:textColorHint">?attr/offside_onSecondaryVariant</item>
        <item name="endIconTintMode">src_in</item>
        <item name="endIconTint">?attr/offside_onSecondaryVariant</item>
    </style>

    <style name="Offside.Redesign.InputField.ErrorTextAppearance" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">?attr/offside_error</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase.Password">
        <item name="hintTextAppearance">@style/Offside.Redesign.BodySmallTextStyle</item>
        <item name="passwordToggleDrawable">@drawable/selector_field_input_password_toggle_background</item>
        <item name="passwordToggleTint">@null</item>
        <item name="passwordToggleTintMode">multiply</item>
        <item name="passwordToggleEnabled">true</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase.Active.Counter">
        <item name="counterEnabled">true</item>
        <item name="counterTextColor">?attr/offside_onSurfaceVariantLow</item>
        <item name="counterTextAppearance">@style/Offside.Redesign.LabelMediumTextStyle</item>
        <item name="errorTextAppearance">@style/Offside.Redesign.InputField.ErrorTextAppearance</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase.Active.Icon">
        <item name="endIconDrawable">@drawable/ic_actionable_calendar</item>
        <item name="endIconMode">custom</item>
    </style>

    <style name="Offside.Redesign.InputField.TextLayoutBase.Active.Last">
        <item name="boxStrokeWidth">@dimen/spacing.unset</item>
    </style>

    <style name="Offside.Redesign.InputField.EditTextBase" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:theme">@style/Theme.Offside.Base.EditText</item>
        <item name="android:imeOptions">actionDone</item>
        <item name="android:textAppearance">@style/Offside.Redesign.BodyLargeTextStyle</item>
        <item name="android:textColor">?attr/offside_onSurface</item>
        <item name="android:paddingStart">@dimen/spacing.unset</item>
        <item name="android:paddingEnd">@dimen/padding.large</item>
        <item name="android:paddingLeft">@dimen/spacing.unset</item>
        <item name="android:paddingRight">@dimen/padding.large</item>
        <item name="android:inputType">text</item>
        <item name="backgroundTint">?attr/offside_transparent</item>
    </style>

    <style name="Offside.Redesign.InputField.EditTextBase.EmptyWhite">
        <item name="android:textColor">?attr/offside_onSecondaryVariant</item>
        <item name="background">@drawable/selector_field_input_edittext_background</item>
    </style>

    <style name="Offside.Redesign.InputField.EditTextBase.Active">
        <item name="background">@drawable/selector_field_input_edittext_background</item>
    </style>

    <style name="Offside.Redesign.InputField.EditTextBase.Inactive">
        <item name="background">@drawable/selector_field_input_edittext_background</item>
        <item name="android:enabled">false</item>
    </style>

    <style name="Offside.Redesign.InputField.EditTextBase.Active.MultiLine">
        <item name="android:inputType">textMultiLine</item>
    </style>

    <style name="Theme.Offside.Base.EditText" parent="Theme.Offside.Base">
        <item name="android:colorControlActivated">?attr/offside_accent</item>
    </style>

    <!-- Styles for Input field with Helper Text and Icon -->

    <style name="Offside.Redesign.InputField.TextLayoutBase.Active.Helper">
        <item name="boxStrokeWidth">@dimen/spacing.unset</item>
        <item name="boxStrokeWidthFocused">@dimen/spacing.unset</item>
    </style>

    <style name="Offside.Redesign.InputField.ErrorTextStyle.HelperIconAndTextFieldLabel" parent="Widget.AppCompat.TextView">
        <item name="android:gravity">center_vertical</item>
        <item name="android:textAppearance">@style/Offside.Redesign.BodySmallTextStyle</item>
        <item name="android:textColor">?attr/offside_error</item>
    </style>

    <style name="Offside.Redesign.InputField.ErrorTextStyle.HelperIconAndTextFieldLabel.HelperIconAndText" parent="Widget.AppCompat.TextView">
        <item name="android:paddingBottom">@dimen/padding.medium</item>
        <item name="android:textColor">?attr/offside_error</item>
    </style>

    <style name="Offside.Redesign.InputField.DividerStyle.HelperTextAndIcon" parent="Offside.Redesign.Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="dividerColor">?attr/offside_error</item>
    </style>

</resources>