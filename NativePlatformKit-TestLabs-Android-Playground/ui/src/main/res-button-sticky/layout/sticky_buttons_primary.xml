<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?offside_surface"
    android:elevation="@dimen/offside.redesign.elevation.surface.navigation">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/primary_button"
        style="@style/Offside.Redesign.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Placeholder Text"
        android:layout_marginStart="@dimen/gutter.xsmall"
        android:layout_marginEnd="@dimen/gutter.xsmall"
        android:layout_marginTop="@dimen/margin.small"
        android:layout_marginBottom="@dimen/gutter.large"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>