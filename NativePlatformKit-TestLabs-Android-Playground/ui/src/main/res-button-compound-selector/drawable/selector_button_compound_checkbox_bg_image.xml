<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="true"
        android:state_checked="false"
        android:drawable="@drawable/image_button_checkbox_unselected" />

    <item
        android:state_enabled="true"
        android:state_checked="true"
        android:drawable="@drawable/image_button_checkbox_selected" />

    <item
        android:state_enabled="false"
        android:state_checked="false"
        android:drawable="@drawable/image_button_checkbox_unselected_and_disabled" />

    <item
        android:state_enabled="false"
        android:state_checked="true"
        android:drawable="@drawable/image_button_checkbox_selected_and_disabled" />
</selector>