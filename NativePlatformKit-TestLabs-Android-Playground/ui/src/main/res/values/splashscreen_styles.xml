<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Offside.Application.Component.Splashscreen" parent="Theme.SplashScreen.IconBackground">
        <!-- Set the splash screen background, animated icon, and animation
        duration. -->
        <item name="windowSplashScreenBackground">?attr/offside_primary</item>
        <item name="windowSplashScreenIconBackgroundColor">?attr/offside_primary</item>

        <!-- Use windowSplashScreenAnimatedIcon to add a drawable or an animated
             drawable. One of these is required. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_decorative_book</item>
        <!-- Required for animated icons. -->
        <item name="windowSplashScreenAnimationDuration">200</item>

        <!-- Set the theme of the Activity that directly follows your splash
        screen. This is required. -->
        <item name="postSplashScreenTheme">@style/Theme.Offside.Base.Retail</item>
    </style>
</resources>