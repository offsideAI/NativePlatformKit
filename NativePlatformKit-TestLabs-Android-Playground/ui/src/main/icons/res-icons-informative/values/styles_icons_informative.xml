<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Offside.Redesign.Icons.Informative">
        <item name="android:focusable">false</item>
    </style>
    <style name="Offside.Redesign.Icons.Informative.Warning">
        <item name="android:src">@drawable/ic_informative_warning_regular</item>
        <item name="android:contentDescription">@string/a11y_informative_icon_warning</item>
    </style>
    <style name="Offside.Redesign.Icons.Informative.Recurring">
        <item name="android:src">@drawable/ic_informative_recurring</item>
        <item name="android:contentDescription">@string/a11y_informative_icon_recurring</item>
    </style>
    <style name="Offside.Redesign.Icons.Informative.Recurring.Focusable">
        <item name="android:focusable">true</item>
        <item name="android:importantForAccessibility">yes</item>
        <item name="android:src">@drawable/ic_informative_recurring</item>
        <item name="android:contentDescription">@string/a11y_informative_icon_recurring</item>
    </style>

</resources>