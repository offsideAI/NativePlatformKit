<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/offside_surfaceContainer">

        <ai.offside.mobile.android.component.ui.badges.InfoBadge
            android:id="@+id/title_container_icon"
            android:layout_width="@dimen/spacing.match_constraint"
            android:layout_height="@dimen/spacing.match_constraint"
            android:importantForAccessibility="no"
            android:background="@drawable/blue_circle_background"
            android:layout_marginStart="@dimen/padding.large"
            android:layout_marginEnd="@dimen/padding.large"
            app:infoBadgeType="CUSTOM"
            app:infoBadgeWidth="CUSTOM"
            app:layout_constraintWidth_percent="@dimen/title.container.icon.size"
            app:layout_constraintDimensionRatio="@dimen/size.ratio.xxsmall"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/title_container_title" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/title_container_title"
            style="@style/Offside.Redesign.HeadlineMediumTextStyle"
            android:layout_width="@dimen/spacing.unset"
            android:layout_height="wrap_content"
            android:paddingEnd="@dimen/padding.xxlarge"
            android:singleLine="true"
            android:textColor="?attr/offside_onSurface"
            android:accessibilityHeading="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/title_container_icon"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Placeholder Text" />

        <com.google.android.material.divider.MaterialDivider
            style="@style/Offside.Redesign.Divider"
            android:layout_width="@dimen/spacing.match_constraint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_container_icon"
            android:layout_marginTop="@dimen/padding.large"/>

</androidx.constraintlayout.widget.ConstraintLayout>
