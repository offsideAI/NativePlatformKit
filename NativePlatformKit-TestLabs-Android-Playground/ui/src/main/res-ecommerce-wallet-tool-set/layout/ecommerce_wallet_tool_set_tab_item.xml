<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="feature"
            type="ai.offside.mobile.android.component.ui.listitem.data.ListItemData.ListItemWithIcon" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tool_set_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:descendantFocusability="blocksDescendants"
        android:focusable="true"
        android:importantForAccessibility="yes"
        android:onClick="@{v->feature.onClick(v)}"
        android:paddingVertical="@dimen/padding.xxlarge"
        >

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no"
            app:imageResource="@{feature.iconRes}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_feature_ecommerce_wallet_spending_and_budget"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/label"
            android:layout_width="@dimen/spacing.match_constraint"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingTop="@dimen/padding.xsmall"
            android:text="@{feature.label}"
            android:textAppearance="@style/Offside.Redesign.LabelSmallTextStyle"
            android:textColor="?attr/offside_onSurfaceVariantLow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/icon"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>