<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="ai.offside.mobile.android.component.ui.tile.paymentaccount.data.PaymentAccountTileData" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/payment_due_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/padding.xlarge"
        android:importantForAccessibility="yes"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/monthly_payment_due_label"
            style="@style/Offside.Redesign.PaymentAccountTile.PaymentDue.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{data.monthlyPaymentDue.label}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/monthly_payment_due"
            style="@style/Offside.Redesign.PaymentAccountTile.PaymentDue.Value"
            android:layout_width="@dimen/spacing.unset"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:amountText="@{data.monthlyPaymentDue.value}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>