<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools"
    >

    <data>

        <import type="android.view.View" />

        <variable
            name="data"
            type="ai.offside.mobile.android.component.ui.tile.paymentaccount.data.PaymentAccountTileDataModel" />
    </data>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/offside_surfaceContainer"
        app:cardElevation="@dimen/offside.redesign.elevation.surface.raised"
        app:cardUseCompatPadding="true"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="@dimen/padding.xxlarge">

            <include
                android:id="@+id/header"
                layout="@layout/payments_account_tile_widget_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                bind:data="@{data}"
                />

            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:dividerColor="?attr/offside_surfaceContainerLow"
                app:layout_constraintTop_toBottomOf="@+id/header"
                />

            <include
                android:id="@+id/payment_due"
                layout="@layout/payment_account_tile_widget_payment_due"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/divider1"
                bind:data="@{data}"
                />

            <include
                android:id="@+id/payment_due_date"
                layout="@layout/payment_account_tile_widget_payment_due_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding.small"
                app:layout_constraintTop_toBottomOf="@+id/payment_due"
                bind:data="@{data.monthlyPaymentDate}"
                />

            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/balance_field_divider"
                style="@style/Offside.Redesign.Divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding.xlarge"
                android:layout_marginTop="@dimen/padding.xxlarge"
                app:layout_constraintTop_toBottomOf="@+id/payment_due_date"
                />

            <ai.offside.mobile.android.component.ui.tile.reviewfield.ReviewFieldTile
                android:id="@+id/balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding.xlarge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/balance_field_divider"
                app:titleLabel="@{data.balance.label}"
                app:titleValue="@{data.balance.value}"
                />

            <include
                android:id="@+id/last_payment_amount"
                layout="@layout/payment_account_tile_label_value_pair"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding.xlarge"
                android:layout_marginTop="@dimen/padding.xlarge"
                app:layout_constraintTop_toBottomOf="@+id/balance"
                bind:data="@{data.lastPaymentAmount.getPairInString()}"
                />

            <include
                android:id="@+id/last_payment_date"
                layout="@layout/payment_account_tile_label_value_pair"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding.xlarge"
                android:layout_marginTop="@dimen/padding.large"
                app:layout_constraintTop_toBottomOf="@+id/last_payment_amount"
                bind:data="@{data.lastPaymentDate}"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/primary_button"
                style="@style/Offside.Redesign.PaymentAccountTile.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding.xxlarge"
                android:onClick="@{v -> data.primaryButton.onButtonClick(v)}"
                android:text="@{data.primaryButton.label}"
                android:visibility="@{data.primaryButtonVisibility}"
                app:layout_constraintTop_toBottomOf="@+id/last_payment_date"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/secondary_button"
                style="@style/Offside.Redesign.PaymentAccountTile.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding.large"
                android:onClick="@{v -> data.secondaryButton.onButtonClick(v)}"
                android:text="@{data.secondaryButton.label}"
                android:visibility="@{data.secondaryButtonVisibility}"
                app:layout_constraintTop_toBottomOf="@+id/primary_button"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tertiary_button"
                style="@style/Offside.Redesign.PaymentAccountTile.Button.Tertiary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding.large"
                android:onClick="@{v -> data.tertiaryButton.onButtonClick(v)}"
                android:text="@{data.tertiaryButton.label}"
                android:visibility="@{data.tertiaryButtonVisibility}"
                app:layout_constraintTop_toBottomOf="@+id/secondary_button"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>