<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="data"
            type="ai.offside.mobile.android.component.ui.tile.account.data.AccountTileLabelValuePair" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/payment_due_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/padding.xlarge"
        android:layout_marginTop="@dimen/padding.medium"
        android:importantForAccessibility="yes"
        android:focusable="true"
        android:focusableInTouchMode="true"
        >

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/monthly_payment_due_date_label"
            style="@style/Offside.Redesign.PaymentAccountTile.PaymentDueDate.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{data.label}"
            app:layout_constraintBottom_toBottomOf="@+id/payment_due_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/payment_due_date"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/payment_due_date"
            style="@style/Offside.Redesign.PaymentAccountTile.PaymentDueDate.Value"
            android:layout_width="@dimen/spacing.unset"
            android:layout_height="wrap_content"
            android:text="@{data.value}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>