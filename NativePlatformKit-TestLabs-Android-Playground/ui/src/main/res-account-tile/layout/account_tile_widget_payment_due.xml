<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="ai.offside.mobile.android.component.ui.tile.account.data.AccountTilePaymentStatus"/>

        <variable
            name="data"
            type="ai.offside.mobile.android.component.ui.tile.account.data.AccountTileData.AccountTileWidgetPaymentDue" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/min_payment_amount"
            style="@style/Offside.Redesign.AccountTile.PaymentDue"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@{data.paymentDueAmountLabel}"
            android:visibility="@{data.dueInfoVisibility, default=visible}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/min_payment_due_date"
            style="@style/Offside.Redesign.AccountTile.PaymentDue"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/spacing.unset"
            android:text="@{data.paymentDueDateLabel}"
            android:visibility="@{data.dueInfoVisibility, default=visible}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/min_payment_amount"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/min_payment_due_indicator"
            style="@style/Offside.Redesign.AccountTile.PaymentDue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_general_badge_checkmark"
            android:text="@{context.getString(AccountTilePaymentStatus.NO_DUE.labelRes)}"
            android:visibility="@{data.noPaymentDueVisibility, default=gone}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/payment_overdue_indicator"
            style="@style/Offside.Redesign.AccountTile.PaymentOverdue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_decorative_exclamation_solid"
            android:text="@{context.getString(AccountTilePaymentStatus.OVERDUE.labelRes)}"
            android:visibility="@{data.paymentOverdueVisibility, default=gone}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

