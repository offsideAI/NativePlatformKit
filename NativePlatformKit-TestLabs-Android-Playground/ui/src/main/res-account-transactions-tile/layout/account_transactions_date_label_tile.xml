<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/offside_surfaceContainerLowest">

    <com.google.android.material.textview.MaterialTextView
        style="@style/Offside.Redesign.TransactionTile.Date.Label"
        android:id="@+id/transaction_date_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:accessibilityHeading="true"
        android:paddingHorizontal="@dimen/padding.large"
        android:paddingVertical="@dimen/padding.small"
        android:screenReaderFocusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>