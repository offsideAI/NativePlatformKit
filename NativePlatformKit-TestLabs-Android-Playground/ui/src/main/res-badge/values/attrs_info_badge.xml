<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="InfoBadge">
        <attr name="infoBadgeType" format="enum">
            <enum name="SUCCESS" value="0" />
            <enum name="WARNING" value="1" />
            <enum name="CHECKMARK" value="2" />
            <enum name="CUSTOM" value="3" />
        </attr>
        <attr name="infoBadgeIcon" format="reference" />
        <attr name="infoBadgeContentDescription" format="reference|string" />
        <attr name="infoBadgeUrl" format="reference|string" />
        <attr name="infoBadgeWidth" format="enum">
            <enum name="FIXED" value="0" />
            <enum name="CUSTOM" value="1" />
        </attr>
    </declare-styleable>
</resources>