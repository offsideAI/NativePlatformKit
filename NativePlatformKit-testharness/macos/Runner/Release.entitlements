<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled: see DebugProfile.entitlements. The harness shells out to the Android
	     SDK toolchain and writes screenshots to arbitrary paths, which the sandbox forbids. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
